{"version":3,"kind":"Article","sha256":"a5cfd443b227d48d765349d4fa84d997fe150359d6b27bf4e80408705f23a253","slug":"chapter-summary","location":"/Chapter_Summary.md","dependencies":[],"frontmatter":{"title":"📝📉 Chapter Summary","content_includes_title":false,"authors":[{"nameParsed":{"literal":"Financial Python","given":"Financial","family":"Python"},"name":"Financial Python","id":"contributors-myst-generated-uid-0"}],"github":"https://github.com/PatrickJHess/Volume-Four-Chapter-Three","copyright":"2025 by the University of Virginia Darden School Foundation, Charlottesville, VA.","numbering":{"title":{"offset":1}},"source_url":"https://github.com/PatrickJHess/Volume-Four-Chapter-Three/blob/main/Chapter_Summary.md","edit_url":"https://github.com/PatrickJHess/Volume-Four-Chapter-Three/edit/main/Chapter_Summary.md","exports":[{"format":"md","filename":"Chapter_Summary.md","url":"/Volume-Four-Chapter-Three//build/Chapter_Summary-8d4a24c12cad807e89ea3d1cd837c560.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"break","key":"eRX54xis0V"},{"type":"paragraph","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"text","value":"The yield to maturity (YTM) of a bond is a vital summary metric representing the internal rate of return that equates the present value of a bond’s future cash flows—both their timing and value—to its current market price. Crucially, this metric illustrates the inverse relationship between bond prices and yields: as yields rise, bond prices fall.","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"hvjb2ZCY3N"}],"key":"ha5bpYwRdY"},{"type":"heading","depth":2,"position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"text","value":"⚠️ How Should YTM Be Used? (Carefully)","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"Z32mcBM0qm"}],"identifier":"id-how-should-ytm-be-used-carefully","label":"⚠️ How Should YTM Be Used? (Carefully)","html_id":"id-how-should-ytm-be-used-carefully","implicit":true,"key":"NtB2y5fBbJ"},{"type":"paragraph","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"The most direct and accurate applications of YTM are for default-free, non-callable bonds with certain payment dates and amounts. Even under perfect conditions, YTM leaves several practical realities unresolved. It fails to guarantee:","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"QE1NeA7jIg"}],"key":"dKD3EQwHyZ"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":11,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":11,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"strong","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"text","value":"The expected rate of return for any single period.","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"xlcrFRO9Gc"}],"key":"EvFpM8Op5H"}],"key":"qB6ajUa984"}],"key":"nQxQWieXmV"},{"type":"listItem","spread":true,"position":{"start":{"line":13,"column":1},"end":{"line":14,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"strong","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"text","value":"The exact total return earned over the life of the investment.","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"htxUmhfXeZ"}],"key":"sQgJmmeV40"},{"type":"text","value":" (YTM strictly assumes the bond is held to maturity and that all coupon payments are reinvested at the exact YTM rate—an unlikely scenario known as reinvestment risk).","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"uJ583Kq0yu"}],"key":"ho497OH77z"}],"key":"uX8a9dIkmo"},{"type":"listItem","spread":true,"position":{"start":{"line":15,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"strong","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"text","value":"An accurate comparative evaluation","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"zWsbcCPuDh"}],"key":"nMGCEMb1xA"},{"type":"text","value":" of bonds with the same maturity date if their coupon rates or default risks differ significantly.","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"JyTteUy1dx"}],"key":"mtwS9gQmyS"}],"key":"pH4qRAviKC"}],"key":"cLpurC2hpJ"},{"type":"heading","depth":2,"position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"text","value":"🛡️ Adjusting for Reality","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"key":"c4G9iTRq2D"}],"identifier":"id-adjusting-for-reality","label":"🛡️ Adjusting for Reality","html_id":"id-adjusting-for-reality","implicit":true,"key":"zvuqWgdcZv"},{"type":"paragraph","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"text","value":"Furthermore, when stepping outside of default-free bonds, YTM must be adjusted to account for credit risk, incorporating a spread to compensate for potential default.","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"f5MUUoEpDf"}],"key":"Fj5ODLK6vp"},{"type":"paragraph","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"children":[{"type":"text","value":"Nevertheless, despite its restrictive assumptions, YTM remains a foundational metric used universally in bond evaluation. It serves as an essential starting point that bond experts use to analyze investment opportunities. Ultimately, understanding how YTM interacts with the term structure of interest rates and credit spreads is the key to unwrapping a bond’s characteristics, pricing its risks, and evaluating its true return potential.","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"TTaLVzAJuj"}],"key":"ebkTdjI84U"}],"key":"dqGRjnBpv8"}],"key":"M5jWgSwTKZ"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"The Term Structure Of Interest Rates Drives Yields To Maturity 📓 📈 🎯","short_title":"The Term Structure Of Interest Rates Drives Yields To Maturity 📓 📈 🎯","url":"/calculating-yields-to-maturity","group":"Chapter Three: Yields To Maturity And The Term Structure Of Interest Rates"},"next":{"title":"🛠️ Imported Functions","short_title":"Imported Functions and FredReader","url":"/imported-functions","group":"Chapter Three: Yields To Maturity And The Term Structure Of Interest Rates"}}},"domain":"http://localhost:3000"}